// 1. Simulação do cadastro atual do medicamento no sistema
let cadastroMedicamento = {
    id: "med-123",
    nome: "Dipirona Monohidratada",
    dosagem: "500mg",
    frequencia: "De 6 em 6 horas",
    instrucoes: "Tomar após as refeições."
};

/**
 * Função responsável por alterar o cadastro do medicamento
 * @param {string} novoNome 
 * @param {string} novaDosagem 
 * @param {string} novaFrequencia 
 * @param {string} novasInstrucoes 
 */
function alterarCadastroMedicamento(novoNome, novaDosagem, novaFrequencia, novasInstrucoes) {
    // Validação simples: não permite salvar se o nome estiver em branco
    if (!novoNome || novoNome.trim() === "") {
        alert("Erro: O nome do medicamento é obrigatório para o cadastro!");
        return;
    }

    // 2. Altera os dados no objeto de cadastro (Lógica de Banco/Memória)
    cadastroMedicamento.nome = novoNome;
    cadastroMedicamento.dosagem = novaDosagem;
    cadastroMedicamento.frequencia = novaFrequencia;
    cadastroMedicamento.instrucoes = novasInstrucoes;

    console.log("Cadastro alterado com sucesso no sistema:", cadastroMedicamento);

    // 3. Altera o HTML para refletir o novo cadastro na tela do usuário
    document.getElementById("txt-nome").innerText = cadastroMedicamento.nome;
    document.getElementById("txt-dosagem").innerText = cadastroMedicamento.dosagem;
    document.getElementById("txt-frequencia").innerText = cadastroMedicamento.frequencia;
    document.getElementById("txt-instrucoes").innerText = cadastroMedicamento.instrucoes;

    alert("O cadastro do medicamento foi alterado com sucesso!");
}

// Exemplo de como o seu botão do HTML chamaria essa função ao ser clicado:
function buscarNovosDadosDaTela() {
    // Pega os valores que o usuário digitou nos campos de texto (inputs)
    let nomeDigitado = document.getElementById("input-nome").value;
    let dosagemDigitada = document.getElementById("input-dosagem").value;
    let frequenciaDigitada = document.getElementById("input-frequencia").value;
    let instrucoesDigitadas = document.getElementById("input-instrucoes").value;

    // Dispara a função principal de alteração
    alterarCadastroMedicamento(nomeDigitado, dosagemDigitada, frequenciaDigitada, instrucoesDigitadas);
}