// Função para abrir o formulário com os dados atuais da Loratadina
function abrirFormularioEditar() {
    // 1. Pega os dados que já estão na tabela
    const nomeAtual = document.getElementById("med-nome-1").innerText;
    const doseAtual = document.getElementById("med-dose-1").innerText;
    
    // 2. Joga esses dados para dentro dos inputs do formulário de alteração
    document.getElementById("input-alterar-nome").value = nomeAtual;
    document.getElementById("input-alterar-dose").value = doseAtual;
    
    // 3. Mostra o painel do formulário na tela (reovendo o 'display: none')
    document.getElementById("painel-formulario-edicao").style.display = "block";
}

// Função que executa a TROCA do medicamento de fato
function salvarAlteracaoMedicamento(event) {
    event.preventDefault(); // Impede a página de recarregar

    // 1. Pega os novos valores que o usuário digitou no momento que quis alterar
    const novoNome = document.getElementById("input-alterar-nome").value;
    const novaDose = document.getElementById("input-alterar-dose").value;
    const novaImportancia = document.getElementById("select-alterar-importancia").value;

    // Validação simples para não salvar em branco
    if (!novoNome.trim() || !novaDose.trim()) {
        alert("Por favor, preencha o nome e a dose do novo medicamento!");
        return;
    }

    // 2. ALTERAÇÃO NO HTML: Substitui os dados velhos da Loratadina pelos novos na tabela
    document.getElementById("med-nome-1").innerText = novoNome;
    document.getElementById("med-dose-1").innerText = novaDose;
    
    // Atualiza a etiqueta de importância (Mudando a cor do HTML baseado na escolha)
    const tagImportancia = document.getElementById("med-importancia-1");
    tagImportancia.innerText = novaImportancia;
    
    if (novaImportancia === "Urgente" || novaImportancia === "Alta") {
        tagImportancia.style.backgroundColor = "#ffcccc";
        tagImportancia.style.color = "#cc0000";
    } else {
        tagImportancia.style.backgroundColor = "#fef9e7";
        tagImportancia.style.color = "#b7950b"; // Amarelo/Médio original
    }

    // 3. Fecha o formulário após salvar
    fecharFormulario();
    alert("Medicamento trocado com sucesso no sistema!");
}

function fecharFormulario() {
    document.getElementById("painel-formulario-edicao").style.display = "none";
}